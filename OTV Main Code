int PIN_MOTOR_2_REVERSE = 8;
int PIN_MOTOR_2_SPEED = 32;
//Ultrasonic Assignments
int PIN_US_FRONT_TRIG = 18;
int PIN_US_FRONT_ECHO = 19;
