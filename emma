void turn(float degree) {
  float d;
  d = getShortestTurn(t, degree);
  if (d > 0) {
    while (abs(degree - t) > .1) {
      Tank.setLeftMotorPWM(-31);
      Tank.setRightMotorPWM(31);
      t = Enes100.getTheta();
    }
    Tank.setLeftMotorPWM(0);
    Tank.setRightMotorPWM(0);
    while (abs(degree - t) > .001) {
      Tank.setLeftMotorPWM(-3);
      Tank.setRightMotorPWM(3);
      t = Enes100.getTheta();
    }
    Tank.setLeftMotorPWM(0);
    Tank.setRightMotorPWM(0);
  } else {
    while (abs(degree - t) > .1) {
      Tank.setLeftMotorPWM(31);
      Tank.setRightMotorPWM(-31);
      t = Enes100.getTheta();
    }
    Tank.setLeftMotorPWM(0);
    Tank.setRightMotorPWM(0);
    while (abs(degree - t) > .001) {
      Tank.setLeftMotorPWM(3);
      Tank.setRightMotorPWM(-3);
      t = Enes100.getTheta();
    }
    Tank.setLeftMotorPWM(0);
    Tank.setRightMotorPWM(0);
  }
}

void goToY(float Y) {
  if (Y > y) {
    turn(HALF_PI);
  } else {
    turn(-1 * HALF_PI);
  }
  while (abs(Y - y) > .05) {
    Tank.setLeftMotorPWM(31);
    Tank.setRightMotorPWM(31);
    y = Enes100.getY();
  }
  Tank.setLeftMotorPWM(0);
  Tank.setRightMotorPWM(0);
  while (abs(Y - y) > 0.001) {
    Tank.setLeftMotorPWM(3);
    Tank.setRightMotorPWM(3);
    y = Enes100.getY();
  }
  Tank.setLeftMotorPWM(0);
  Tank.setRightMotorPWM(0);
}

void goToX(float X) {
  if (X > x) {
    turn(0);
  } else {
    turn(PI);
  }
  while (abs(X - x) > .05) {
    Tank.setLeftMotorPWM(31);
    Tank.setRightMotorPWM(31);
    x = Enes100.getX();
  }
  Tank.setLeftMotorPWM(0);
  Tank.setRightMotorPWM(0);
  while (abs(X - x) > 0.001) {
    Tank.setLeftMotorPWM(3);
    Tank.setRightMotorPWM(3);
    x = Enes100.getX();
  }
  Tank.setLeftMotorPWM(0);
  Tank.setRightMotorPWM(0);
}

void reverseY(float dist) {
  float desired;
  if (t > 0) {
    desired = y - dist;
    while (abs(y - desired) > .05) {
      Tank.setLeftMotorPWM(-31);
      Tank.setRightMotorPWM(-31);
      y = Enes100.getY();
    }
    Tank.setLeftMotorPWM(0);
    Tank.setRightMotorPWM(0);
    while (abs(y - desired) > 0.001) {
      Tank.setLeftMotorPWM(-3);
      Tank.setRightMotorPWM(-3);
      y = Enes100.getY();
    }
  } else {
    desired = y + dist;
    while (abs(y - desired) > .05) {
      Tank.setLeftMotorPWM(-31);
      Tank.setRightMotorPWM(-31);
      y = Enes100.getY();
    }
    Tank.setLeftMotorPWM(0);
    Tank.setRightMotorPWM(0);
    while (abs(y - desired) > 0.001) {
      Tank.setLeftMotorPWM(-3);
      Tank.setRightMotorPWM(-3);
      y = Enes100.getY();
    }
  }
  Tank.setLeftMotorPWM(0);
  Tank.setRightMotorPWM(0);
  Tank.setLeftMotorPWM(0);
  Tank.setRightMotorPWM(0);
}

void startUltrasonic() {
  // Short low pulse
  digitalWrite(trigPin, LOW);
  delayMicroseconds(5);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Read signal
  pinMode(echoPin, INPUT);
  duration = pulseIn(echoPin, HIGH);

  cm = (duration / 2) / 29.1;  // Convert to cm

  // 9.35 distance
  waterDistance = 9.35 - cm;

  int range20 = abs(2.0 - waterDistance);
  int range30 = abs(3.0 - waterDistance);
  int range40 = abs(4.0 - waterDistance);

  // Serial.println("Working");
  if (range20 < range30 && range20 < range40) {
    Enes100.mission(DEPTH, 20);
    Serial.println("20");
  } else if (range30 < range20 && range30 < range40) {
    Enes100.mission(DEPTH, 30);
    Serial.println("30");
  } else {
    Enes100.mission(DEPTH, 40);
    Serial.println("40");
  }





  // inches = (duration/2) / 74;   // Convert to inches
  // Serial.print(inches);
  // Serial.print("in, ");
  Serial.print(cm);
  Serial.print("cm");
  Serial.println();
  delay(250);
}

float getShortestTurn(float t, float degree) {
  float diff;
  diff = degree - t;
  if (diff > PI) {
    diff -= 2.0 * PI;
  } else if (diff <= -1 * PI) {
    diff += 2.0 * PI;
  }
  return diff;
}
